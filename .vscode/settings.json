{
  "python.defaultInterpreterPath": "backend/.venv/Scripts/python.exe",
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.testing.pytestEnabled": true,
  "python.testing.autoTestDiscoverOnSaveEnabled": true,
  "python.testing.pytestArgs": [
    "tests"
  ],
  "python.testing.cwd": "${workspaceFolder}/backend",
  "coverage-gutters.coverageFileNames": [
    "backend/coverage.xml",
    "frontend/coverage/lcov.info",
    "coverage.xml"
  ],
  "coverage-gutters.showLineCoverage": true,
  "coverage-gutters.watchFiles": true,
  "coverage-gutters.partialLineColor": "rgba(255, 165, 0, 0.5)",
  "coverage-gutters.remotePathMapping": {},
  "python.envFile": "${workspaceFolder}/backend/.env",
  "files.trimTrailingWhitespace": true,
  "editor.formatOnSave": true,
  "files.associations": {
    "**/templates/*.html": "django-html",
    "**/requirements{/**,*}.{txt,in}": "pip-requirements",
    "nginx.conf": "nginx",
    "**/nginx/*.conf": "nginx",
    "**/nginx.conf": "nginx",
    "*.env.example": "dotenv",
    "*.env.local": "dotenv"
  },
  // --- Python & Ruff ---
  "[python]": {
    "editor.tabSize": 4,
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "always",
      "source.organizeImports.ruff": "always"
    }
  },
  "ruff.configuration": {
    "format": {
      "quote-style": "single"
    },
    "lint": {
      "select": [
        "E",
        "F",
        "I"
      ]
    }
  },
  // --- Frontend (JS/TS) & Prettier ---
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "prettier.singleQuote": true,
  "prettier.trailingComma": "all",
  "prettier.semi": true,
  "prettier.printWidth": 100,
  "prettier.pluginSearchDirs": [
    "${workspaceFolder}/frontend/node_modules"
  ],
  "[typescript]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // --- Other ---
  "[json]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[nginx]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "prettier.documentSelectors": [
    "**/*.tsx",
    "**/*.ts"
  ],
  "prettier.configPath": "frontend/.prettierrc",
  "prettier.requireConfig": true,
  "prettier.resolveConfigRelativeToRoot": true,
  "python.testing.unittestEnabled": false
}