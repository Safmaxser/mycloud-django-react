# --- Security & Debug ---
DEBUG=False
SECRET_KEY=my_secret_key
ALLOWED_HOSTS=127.0.0.1,localhost

# --- Database (PostgreSQL) ---
DB_NAME=cloud_db
DB_USER=my_user
DB_PASSWORD=my_password
DB_HOST=db
DB_PORT=5432

# --- CORS & CSRF Settings ---
# Comma-separated list of origins (React dev server ports)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Cookie Settings ---
# Leave empty for local development. Use your domain (e.g., .yourdomain.com) for production.
SESSION_COOKIE_DOMAIN=
CSRF_COOKIE_DOMAIN=
