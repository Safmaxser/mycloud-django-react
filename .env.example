# --- Network & Identity ---
SITE_PROTOCOL=https
SITE_DOMAIN=yourdomain.ru
SITE_IP=95.163.x.x
ACME_EMAIL=admin@yourdomain.ru

# --- SSL & Traefik Controls ---
# true — для работы через HTTPS, false — для работы по IP (HTTP)
ENABLE_SSL=true
TRAEFIK_ENTRYPOINT=websecure

# --- Security & Debug ---
DEBUG=False
SECRET_KEY=my_secret_key
ALLOWED_HOSTS=localhost,127.0.0.1,${SITE_DOMAIN},${SITE_IP}

# --- Database (PostgreSQL) ---
DB_NAME=cloud_db
DB_USER=my_user
DB_PASSWORD=my_password
DB_HOST=db
DB_PORT=5432

# --- Infrastructure & Cache ---
# Зеркало для ускорения сборки на RU-серверах
DOCKER_REGISTRY_MIRROR=cr.yandex/mirror/
BASE_REDIS_URL=redis://redis:6379

# --- CORS & CSRF Settings ---
CORS_ALLOWED_ORIGINS=${SITE_PROTOCOL}://${SITE_DOMAIN}
CSRF_TRUSTED_ORIGINS=${SITE_PROTOCOL}://${SITE_DOMAIN}

# --- Cookie Settings ---
SESSION_COOKIE_DOMAIN=.${SITE_DOMAIN}
CSRF_COOKIE_DOMAIN=.${SITE_DOMAIN}
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# --- Storage & File Management ---
# Quota limit for each user in bytes (e.g., 2GB = 2147483648)
STORAGE_QUOTA_BYTES=2147483648
# Maximum size allowed for a single file upload (e.g., 500MB = 524288000)
MAX_FILE_SIZE_BYTES=524288000
# Method used to serve files: 'django' for development, 'nginx' for production
FILE_SERVE_METHOD=nginx
